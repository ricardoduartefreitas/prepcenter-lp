---
// src/components/LeadForm.astro
// PUBLIC_TURNSTILE_SITE_KEY: configurar variável de ambiente no Cloudflare Pages
// SUPABASE_URL: URL da Edge Function do Supabase rfaskndtdixdhpdwrydy
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "CONFIGURE_NO_CLOUDFLARE";
const TURNSTILE_ATIVA = TURNSTILE_SITE_KEY !== "CONFIGURE_NO_CLOUDFLARE";
const EDGE_FN_URL = "https://rfaskndtdixdhpdwrydy.supabase.co/functions/v1/submit-prepcenter-lead";
---
{/* Carrega o script do Turnstile apenas quando a site key estiver configurada */}
{TURNSTILE_ATIVA && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
<div id="lead-form-wrapper" class="bg-white rounded-2xl border border-[var(--color-border)] shadow-lg p-8">
  <form id="lead-form" novalidate>
    <div class="grid sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label for="lf-nome" class="block text-sm font-medium text-[var(--color-text)] mb-1">
          Seu nome *
        </label>
        <input
          id="lf-nome"
          name="nome"
          type="text"
          required
          autocomplete="name"
          placeholder="João Silva"
          class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-orange)]"
        />
      </div>
      <div>
        <label for="lf-wa" class="block text-sm font-medium text-[var(--color-text)] mb-1">
          WhatsApp *
        </label>
        <input
          id="lf-wa"
          name="whatsapp"
          type="tel"
          required
          autocomplete="tel"
          placeholder="(62) 99999-9999"
          class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-orange)]"
        />
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label for="lf-volume" class="block text-sm font-medium text-[var(--color-text)] mb-1">
          Volume médio por dia *
        </label>
        <select
          id="lf-volume"
          name="volume"
          required
          class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-orange)]"
        >
          <option value="">Selecione...</option>
          <option value="<10">Menos de 10 pedidos/dia</option>
          <option value="10-30">10 a 30 pedidos/dia</option>
          <option value="30-100">30 a 100 pedidos/dia</option>
          <option value=">100">Mais de 100 pedidos/dia</option>
        </select>
      </div>
      <div>
        <label for="lf-marketplace" class="block text-sm font-medium text-[var(--color-text)] mb-1">
          Marketplace principal *
        </label>
        <select
          id="lf-marketplace"
          name="marketplace"
          required
          class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-orange)]"
        >
          <option value="">Selecione...</option>
          <option value="TikTok Shop">TikTok Shop</option>
          <option value="Shopee">Shopee</option>
          <option value="Shein">Shein</option>
          <option value="AliExpress">AliExpress</option>
          <option value="Kwai">Kwai</option>
          <option value="Temu">Temu</option>
          <option value="Outro">Outro</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <label for="lf-skus" class="block text-sm font-medium text-[var(--color-text)] mb-1">
        Quantos produtos diferentes (SKUs) você vende? *
      </label>
      <select
        id="lf-skus"
        name="skus"
        required
        class="w-full border border-[var(--color-border)] rounded-lg px-4 py-3 text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-orange)]"
      >
        <option value="">Selecione...</option>
        <option value="1-5">Até 5 produtos</option>
        <option value="6-20">6 a 20 produtos</option>
        <option value="21-50">21 a 50 produtos</option>
        <option value=">50">Mais de 50 produtos</option>
      </select>
    </div>

    <!-- Checkbox LGPD -->
    <div class="flex items-start gap-3 mb-4">
      <input
        id="lf-lgpd"
        name="lgpd"
        type="checkbox"
        required
        class="mt-1 h-4 w-4 accent-[var(--color-brand-orange)]"
      />
      <label for="lf-lgpd" class="text-xs text-[var(--color-text-muted)] leading-relaxed">
        Autorizo receber mensagens automáticas via WhatsApp da Ruah Tecnologia sobre o serviço de fulfillment.
        Consulte nossa <a href="/privacidade" class="underline text-[var(--color-brand-blue)]" rel="noopener noreferrer">Política de Privacidade</a>.
      </label>
    </div>

    <!-- Cloudflare Turnstile (só renderiza quando site key estiver configurada) -->
    {TURNSTILE_ATIVA && (
      <div id="turnstile-wrapper" class="mb-4">
        <div
          class="cf-turnstile"
          data-sitekey={TURNSTILE_SITE_KEY}
          data-theme="light"
          data-error-callback="turnstileOnError"
        ></div>
      </div>
    )}
    <script is:inline>
      window.turnstileOnError = function() {
        var w = document.getElementById('turnstile-wrapper');
        if (w) w.style.display = 'none';
      };
    </script>

    <!-- Erro -->
    <div id="lf-erro" class="hidden mb-4 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3"></div>

    <button
      type="submit"
      id="lf-btn"
      class="w-full bg-[var(--color-brand-orange)] hover:bg-orange-600 disabled:opacity-60 text-white font-[var(--font-display)] font-semibold px-8 py-4 rounded-lg text-lg transition-colors"
    >
      Quero começar agora →
    </button>
  </form>

  <!-- Sucesso -->
  <div id="lf-sucesso" class="hidden text-center py-8">
    <div class="text-4xl mb-4">✅</div>
    <h3 class="font-[var(--font-display)] font-bold text-xl text-[var(--color-text)] mb-2">
      Recebemos seu contato!
    </h3>
    <p class="text-[var(--color-text-muted)] mb-2">
      Clique no botão abaixo para falar com a Ester agora
      e receber sua simulação de custo personalizada.
    </p>
    <p class="text-xs text-[var(--color-text-muted)] mb-6">
      A conversa começa quando você enviar a mensagem.
    </p>
    <a
      href="https://wa.me/5562981366800?text=Ol%C3%A1%2C+acabei+de+preencher+o+formul%C3%A1rio+do+Prep+Center+e+quero+saber+mais"
      class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-green-600 text-white font-semibold px-8 py-4 rounded-lg text-lg transition-colors"
      rel="noopener noreferrer"
      target="_blank"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Falar com a Ester agora
    </a>
  </div>
</div>

<script define:vars={{ EDGE_FN_URL }}>
  const form = document.getElementById('lead-form');
  const btn = document.getElementById('lf-btn');
  const erroEl = document.getElementById('lf-erro');
  const sucessoEl = document.getElementById('lf-sucesso');

  function getUTMs() {
    const p = new URLSearchParams(window.location.search);
    return {
      utm_source: p.get('utm_source') ?? '',
      utm_medium: p.get('utm_medium') ?? '',
      utm_campaign: p.get('utm_campaign') ?? '',
      utm_content: p.get('utm_content') ?? '',
      utm_term: p.get('utm_term') ?? '',
    };
  }

  function mostrarErro(msg) {
    erroEl.textContent = msg;
    erroEl.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    erroEl.classList.add('hidden');

    const nome = document.getElementById('lf-nome').value.trim();
    const wa = document.getElementById('lf-wa').value.trim();
    const volume = document.getElementById('lf-volume').value;
    const marketplace = document.getElementById('lf-marketplace').value;
    const skus = document.getElementById('lf-skus').value;
    const lgpd = document.getElementById('lf-lgpd').checked;
    const turnstileEl = document.querySelector('[name="cf-turnstile-response"]');
    const turnstileToken = turnstileEl?.value ?? '';
    const turnstileAtiva = !!document.querySelector('.cf-turnstile');

    if (!nome || !wa || !volume || !marketplace || !skus) {
      mostrarErro('Por favor, preencha todos os campos obrigatórios.');
      return;
    }
    if (!lgpd) {
      mostrarErro('É necessário aceitar os termos para continuar.');
      return;
    }
    if (turnstileAtiva && !turnstileToken) {
      mostrarErro('Complete a verificação de segurança.');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const res = await fetch(EDGE_FN_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome,
          whatsapp: wa,
          volume,
          marketplace,
          skus,
          turnstile_token: turnstileToken,
          lgpd_consent: true,
          ...getUTMs(),
        }),
      });

      const data = await res.json();

      if (!res.ok || !data.success) {
        throw new Error(data.error ?? 'Erro ao enviar');
      }

      // Pixel: Lead
      if (window.fbq) {
        fbq('track', 'Lead', { content_name: 'prepcenter', volume, marketplace });
      }
      // GA4
      if (window.gtag) {
        gtag('event', 'generate_lead', { volume, marketplace });
      }

      form.classList.add('hidden');
      sucessoEl.classList.remove('hidden');

    } catch (err) {
      mostrarErro('Ops! Tivemos um problema. Tente novamente ou nos chame no WhatsApp.');
      btn.disabled = false;
      btn.textContent = 'Quero começar agora →';
    }
  });
</script>
