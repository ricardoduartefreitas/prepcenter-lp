---
// src/components/Marketplaces.astro
const marketplaces = [
  { nome: "TikTok Shop", logo: "/logos/tiktok-shop.svg" },
  { nome: "Shopee",      logo: "/logos/shopee.svg" },
  { nome: "Shein",       logo: "/logos/shein.svg" },
  { nome: "AliExpress",  logo: "/logos/aliexpress.svg" },
  { nome: "Kwai",        logo: "/logos/kwai.svg" },
  { nome: "Temu",        logo: "/logos/temu.svg" },
];
---
<section class="py-12 bg-[var(--color-bg)] border-y border-[var(--color-border)]">
  <div class="max-w-5xl mx-auto px-4 text-center">
    <p class="text-sm font-medium text-[var(--color-text-muted)] uppercase tracking-widest mb-8">
      Atendemos todos os principais marketplaces
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      {marketplaces.map((m) => (
        <img
          src={m.logo}
          alt={m.nome}
          width="160"
          height="56"
          loading="lazy"
          class="h-14 w-auto rounded-lg shadow-sm hover:shadow-md transition-shadow"
        />
      ))}
    </div>
  </div>
</section>
