---
// src/components/Pricing.astro
const planos = [
  {
    icon: "👕",
    categoria: "Envelope",
    produto: "Roupas, acessórios, bijuterias",
    embalagem: "Envelope bolha",
    preco: "R$4,50",
    destaque: false,
  },
  {
    icon: "💄",
    categoria: "Caixa P",
    produto: "Cosméticos, calçados leves, eletrônicos pequenos",
    embalagem: "Caixa até 30×20×10cm",
    preco: "R$6,50",
    destaque: true,
  },
  {
    icon: "🎮",
    categoria: "Caixa M",
    produto: "Utensílios, brinquedos, kits, eletrônicos",
    embalagem: "Caixa até 50×30×20cm",
    preco: "R$9,50",
    destaque: false,
  },
  {
    icon: "📺",
    categoria: "Caixa G",
    produto: "Produtos volumosos, eletrodomésticos",
    embalagem: "Caixa acima de 50cm",
    preco: "R$14,00",
    destaque: false,
  },
];
---
<section class="py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-[var(--font-display)] font-bold text-[var(--color-text)] mb-4">
        Pague só pelo que enviar
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg">
        Sem mensalidade. Sem taxa de cadastro.
        Um valor fixo por pacote despachado — tudo incluso.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {planos.map((p) => (
        <div class={`rounded-2xl border-2 p-6 text-center flex flex-col ${p.destaque ? 'border-[var(--color-brand-orange)] bg-orange-50' : 'border-[var(--color-border)] bg-white'}`}>
          <div class="text-3xl mb-3">{p.icon}</div>
          <h3 class="font-[var(--font-display)] font-bold text-[var(--color-text)] text-lg mb-1">{p.categoria}</h3>
          <p class="text-xs text-[var(--color-text-muted)] mb-3 flex-1">{p.produto}</p>
          <p class="text-xs text-[var(--color-text-muted)] mb-4">{p.embalagem}</p>
          <div class="text-2xl font-[var(--font-display)] font-bold text-[var(--color-brand-orange)]">{p.preco}</div>
          <div class="text-xs text-[var(--color-text-muted)]">por envio</div>
          {p.destaque && <span class="mt-3 text-xs bg-[var(--color-brand-orange)] text-white px-2 py-1 rounded-full">Mais popular</span>}
        </div>
      ))}
    </div>

    <div class="bg-[var(--color-bg-alt)] border border-[var(--color-border)] rounded-xl p-6 grid sm:grid-cols-2 gap-4">
      <div class="flex items-center gap-3">
        <span class="text-xl">+R$2,50</span>
        <div>
          <p class="font-semibold text-[var(--color-text)]">Produto frágil</p>
          <p class="text-sm text-[var(--color-text-muted)]">Proteção extra no pacote</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xl">+R$2,50</span>
        <div>
          <p class="font-semibold text-[var(--color-text)]">Kit ou bundle</p>
          <p class="text-sm text-[var(--color-text-muted)]">2+ itens no mesmo pedido</p>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-[var(--color-text-muted)] mt-4">
      * Custo do frete da transportadora cobrado à parte pelo valor real de tabela (J&T, Jadlog ou Anjun).
    </p>
  </div>
</section>
