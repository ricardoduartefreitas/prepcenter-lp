---
// src/components/CtaFinal.astro
import LeadForm from './LeadForm.astro';
---
<section id="contato" class="py-16 md:py-24 bg-[var(--color-bg-alt)]">
  <div class="max-w-3xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-[var(--font-display)] font-bold text-[var(--color-text)] mb-4">
        Pronto para despachar mais<br />e trabalhar menos?
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg">
        Preencha abaixo e nossa equipe entra em contato em menos de 30 minutos.
      </p>
    </div>
    <LeadForm />
  </div>
</section>
