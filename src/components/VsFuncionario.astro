---
// src/components/VsFuncionario.astro
const funcionario = [
  { item: "Salário + encargos (CLT)", valor: "~R$ 2.800/mês" },
  { item: "13º, férias, FGTS", valor: "~R$ 700/mês (provisionado)" },
  { item: "Equipamentos e espaço físico", valor: "seu custo" },
  { item: "Treinamento e gestão", valor: "seu tempo" },
  { item: "Afastamentos e faltas", valor: "seu risco" },
  { item: "Total estimado", valor: "≥ R$ 3.500/mês" },
];

const ruah = [
  { item: "Mensalidade fixa", valor: "R$ 0,00" },
  { item: "Armazenagem (primeiros 30 dias)", valor: "incluso" },
  { item: "Embalagem + NF + etiqueta", valor: "incluso" },
  { item: "Ponto de coleta credenciado", valor: "incluso" },
  { item: "Gestão de estoque básica", valor: "incluso" },
  { item: "Você paga apenas", valor: "por pedido despachado" },
];
---
<section class="py-16 md:py-24 bg-[var(--color-bg)]">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-[var(--font-display)] font-bold text-[var(--color-text)] mb-4">
        Contratar um funcionário<br />ou usar o Prep Center?
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg max-w-2xl mx-auto">
        Antes de montar sua operação interna, compare o custo real de ter alguém dedicado à logística versus pagar só pelo que despacha.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Funcionário -->
      <div class="rounded-2xl border-2 border-[var(--color-border)] p-6">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-xl">👤</div>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest font-medium">Opção A</p>
            <h3 class="font-[var(--font-display)] font-bold text-[var(--color-text)] text-lg">Funcionário CLT</h3>
          </div>
        </div>
        <ul class="space-y-3">
          {funcionario.map((f, i) => (
            <li class:list={["flex justify-between items-center py-2 border-b border-[var(--color-border)]", i === funcionario.length - 1 && "border-0 font-semibold text-red-600"]}>
              <span class="text-sm text-[var(--color-text-muted)]">{f.item}</span>
              <span class="text-sm font-medium">{f.valor}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Ruah -->
      <div class="rounded-2xl border-2 border-[var(--color-brand-orange)] bg-orange-50 p-6 relative">
        <div class="absolute -top-3 right-6 bg-[var(--color-brand-orange)] text-white text-xs font-semibold px-3 py-1 rounded-full">
          Recomendado
        </div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-xl">📦</div>
          <div>
            <p class="text-xs text-orange-600 uppercase tracking-widest font-medium">Opção B</p>
            <h3 class="font-[var(--font-display)] font-bold text-[var(--color-text)] text-lg">Prep Center Ruah</h3>
          </div>
        </div>
        <ul class="space-y-3">
          {ruah.map((r, i) => (
            <li class:list={["flex justify-between items-center py-2 border-b border-orange-200", i === ruah.length - 1 && "border-0 font-semibold text-[var(--color-brand-orange)]"]}>
              <span class="text-sm text-[var(--color-text-muted)]">{r.item}</span>
              <span class="text-sm font-medium">{r.valor}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="text-center text-sm text-[var(--color-text-muted)] mt-8">
      * Valores de referência para funcionário em GO com salário de R$1.800. Encargos incluem INSS, FGTS, 13º e férias proporcionais.
    </p>
  </div>
</section>
